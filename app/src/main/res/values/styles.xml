<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base App Theme -->
    <style name="Theme.PulsarRider" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_cyan</item>
        <item name="colorPrimaryDark">@color/primary_cyan_dark</item>
        <item name="colorAccent">@color/accent_magenta</item>
        <item name="colorOnPrimary">@color/text_on_cyan</item>
        <item name="colorSecondary">@color/accent_magenta</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/background_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.PulsarRider.Splash" parent="Theme.PulsarRider">
        <item name="android:windowBackground">@color/background_dark</item>
    </style>

    <!-- Cyan Button -->
    <style name="PulsarButton.Cyan" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/text_on_cyan</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/primary_cyan</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Magenta Button -->
    <style name="PulsarButton.Magenta" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/accent_magenta</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Outline Button -->
    <style name="PulsarButton.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary_cyan</item>
        <item name="android:textSize">16sp</item>
        <item name="strokeColor">@color/primary_cyan</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Text Input -->
    <style name="PulsarTextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_cyan</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/background_input</item>
        <item name="hintTextColor">@color/primary_cyan</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Card Style -->
    <style name="PulsarCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Base Text Style -->
    <style name="PulsarText" parent="">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Header Text -->
    <style name="PulsarText.Header">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Subheader Text -->
    <style name="PulsarText.Subheader">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
